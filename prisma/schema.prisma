generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  DRAFT
  LIVE
  ARCHIVED
}

enum SponsorPosition {
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

enum QuizSessionState {
  LOBBY
  QUESTION
  RESULTS
  FINISHED
}

enum SpinChallengeState {
  IDLE
  ACTIVE
  REVIEWING
  COMPLETED
}

enum SpinnerParticipationMode {
  CONCURRENT
  ONE_AT_A_TIME
}

enum SpinnerSessionState {
  ACTIVE
  COMPLETED
}

enum TicTacToeMode {
  CHAMPION
  COUNCIL
}

enum TicTacToeMatchState {
  WAITING
  ACTIVE
  FINISHED
}

enum HangmanMode {
  CHAMPION
  COUNCIL
}

enum HangmanMatchState {
  WAITING
  ACTIVE
  FINISHED
}

enum ActivityCompetitionFormat {
  SINGLE_MATCH
  CHAMPIONSHIP
}

enum ActivityBracketState {
  SETUP
  ACTIVE
  FINISHED
}

enum ActivityBracketRoundState {
  PENDING
  ACTIVE
  COMPLETE
}

enum ActivityBracketSlotState {
  PENDING
  ACTIVE
  COMPLETE
}

enum CountdownSessionState {
  RUNNING
  PAUSED
  FINISHED
}

enum TriviaQuestionType {
  QUIZ
  QUIZ_IMAGE
  TRUE_FALSE
  TYPE_ANSWER
  PUZZLE
  PUZZLE_IMAGE
  SLIDER
  PIN_ANSWER
  QUIZ_AUDIO
}

enum SurveyStatus {
  DRAFT
  OPEN
  CLOSED
}

enum SurveyQuestionType {
  POLL
  WORD_CLOUD
  BRAINSTORM
  DROP_PIN
  OPEN_ENDED
  SCALE
  NPS
}

enum GalleryPhotoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model PlatformRole {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  permissions        Json     @default("[]")
  permissionsVersion Int      @default(0)
  isSystem           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Account {
  id                      String   @id @default(cuid())
  email                   String?  @unique
  username                String   @unique
  passwordHash            String
  firstName               String
  lastName                String
  middleName              String?
  /** Stable cross-event identity from ticket export name + masked email signals. */
  registrationFingerprint String?  @unique
  /** Masked email from ticket export (e.g. b*******@gmail.com) for staff confirmation. */
  maskedEmail             String?
  importSource            String?
  mustChangePassword      Boolean  @default(true)
  permissions             Json     @default("[]")
  permissionsVersion      Int      @default(1)
  /** Created via fg-admin Members — global staff (non-participants) may access any event. */
  globalMember            Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users         User[]
  refreshTokens RefreshToken[]
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String?
  coverImageUrl String?
  date        DateTime
  status             EventStatus @default(DRAFT)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  teams           Team[]
  users           User[]
  agendaItems     AgendaItem[]
  sponsors        Sponsor[]
  messages        Message[]
  quizzes         Quiz[]
  votes           Vote[]
  scoreCriteria   ScoreCriterion[]
  spinChallenges  SpinChallenge[]
  spinnerSessions SpinnerSession[]
  countdownChallenges CountdownChallenge[]
  countdownSessions CountdownSession[]
  ticTacToeChallenges TicTacToeChallenge[]
  ticTacToeMatches    TicTacToeMatch[]
  hangmanChallenges   HangmanChallenge[]
  hangmanMatches      HangmanMatch[]
  activityBrackets    ActivityBracket[]
  surveys         Survey[]
  eventActivities EventActivity[]
  appSettings     AppSetting[]
  auditLogs       AuditLog[]
  photoLibrary    EventPhotoLibrary?
}

model ActivityType {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  description     String?
  sortOrder       Int             @default(0)
  eventActivities EventActivity[]
}

model EventActivity {
  id             String       @id @default(cuid())
  eventId        String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  enabled        Boolean      @default(false)
  allowGeneral   Boolean      @default(false)
  allowGroup     Boolean      @default(false)
  allowStaff     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([eventId, activityTypeId])
}

model EventPhotoLibrary {
  id                 String         @id @default(cuid())
  eventId            String         @unique
  event              Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /** App-created Google Photos album for this event (gallery storage backend). */
  googleAlbumId      String?
  /** Public share link (photos.app.goo.gl) — set manually in event gallery settings. */
  officialGalleryUrl String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  photos             GalleryPhoto[]
}

model GalleryPhoto {
  id                 String             @id @default(cuid())
  libraryId          String
  library            EventPhotoLibrary  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  eventId            String
  uploadedByUserId   String?
  uploadedBy         User?              @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  uploadedByTeamId   String?
  uploadedByTeam     Team?              @relation(fields: [uploadedByTeamId], references: [id], onDelete: SetNull)
  uploadedByTeamName String?
  isOfficial         Boolean            @default(false)
  status             GalleryPhotoStatus @default(PENDING)
  googleMediaItemId  String?
  url                String?
  thumbnailUrl       String?
  urlExpiresAt       DateTime?
  mimeType           String
  mediaWidth         Int?
  mediaHeight        Int?
  originalFilename   String?
  caption            String?
  errorMessage       String?
  uploadedAt         DateTime           @default(now())
  processedAt        DateTime?

  @@index([eventId, status, uploadedAt])
  @@index([libraryId])
  @@index([uploadedByUserId])
  @@index([uploadedByTeamId])
}

model Team {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  letter  String
  name    String
  color   String
  users   User[]
  messages Message[]
  scores  Score[]
  quizAnswers QuizAnswer[]
  spinSubmissions SpinSubmission[]
  voteBallots VoteBallot[]
  quizzes       Quiz[]
  spinChallenges SpinChallenge[]
  spinnerSessions SpinnerSession[]
  ticTacToeMatchesAsX TicTacToeMatch[] @relation("TttTeamX")
  ticTacToeMatchesAsO TicTacToeMatch[] @relation("TttTeamO")
  ticTacToeWins       TicTacToeMatch[] @relation("TttWinner")
  hangmanMatchesAsX   HangmanMatch[]   @relation("HangmanTeamX")
  hangmanMatchesAsO   HangmanMatch[]   @relation("HangmanTeamO")
  hangmanWins         HangmanMatch[]   @relation("HangmanWinner")
  bracketSlotWins     ActivityBracketSlot[] @relation("BracketSlotWinner")
  bracketSlotTeamA    ActivityBracketSlot[] @relation("BracketSlotTeamA")
  bracketSlotTeamB    ActivityBracketSlot[] @relation("BracketSlotTeamB")
  bracketChampionships ActivityBracket[] @relation("BracketChampion")
  galleryPhotos       GalleryPhoto[]

  @@unique([eventId, letter])
}

model User {
  id              String        @id @default(cuid())
  accountId       String
  account         Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authVersion     Int           @default(0)
  /** When set, overrides account permissions for this event only. */
  permissions     Json?
  teamId          String?
  team            Team?         @relation(fields: [teamId], references: [id])
  ticketNumber    String?
  orderNumber     String?
  checkedInAt     DateTime?
  checkedInBy     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  refreshTokens RefreshToken[]
  messages      Message[]      @relation("MessageAuthor")
  directMessages Message[]     @relation("DirectMessageRecipient")
  quizAnswers   QuizAnswer[]
  scoresGiven   Score[]        @relation("JudgeScores")
  voteBallots   VoteBallot[]
  spinSubmissions SpinSubmission[]
  spinnerSpins SpinnerSpin[]
  spinnerSessionsStarted SpinnerSession[] @relation("SpinnerStartedBy")
  spinnerSessionsActive SpinnerSession[] @relation("SpinnerActiveUser")
  countdownSessionsStarted CountdownSession[] @relation("CountdownStartedBy")
  tttChampionX        TicTacToeMatch[] @relation("TttChampionX")
  tttChampionO        TicTacToeMatch[] @relation("TttChampionO")
  hangmanChampionX    HangmanMatch[]   @relation("HangmanChampionX")
  hangmanChampionO    HangmanMatch[]   @relation("HangmanChampionO")
  surveyResponses SurveyResponse[]
  auditLogs     AuditLog[]
  galleryPhotos GalleryPhoto[]

  @@unique([accountId, eventId])
  @@unique([eventId, ticketNumber])
}

model RefreshToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model AgendaItem {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Sponsor {
  id                  String          @id @default(cuid())
  eventId             String
  event               Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label               String
  position            SponsorPosition
  visibleOnPublicOnly Boolean         @default(true)
  createdAt           DateTime        @default(now())

  @@unique([eventId, position])
}

model Message {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  userId      String
  user        User     @relation("MessageAuthor", fields: [userId], references: [id])
  recipientId String?
  recipient   User?    @relation("DirectMessageRecipient", fields: [recipientId], references: [id])
  staffChannel Boolean @default(false)
  body        String
  createdAt   DateTime @default(now())

  @@index([eventId, recipientId, userId])
}

model Quiz {
  id                       String         @id @default(cuid())
  eventId                  String
  event                    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  active                   Boolean        @default(false)
  allowGeneralParticipants Boolean        @default(true)
  allowGroupParticipants   Boolean        @default(false)
  teamId                   String?
  team                     Team?          @relation(fields: [teamId], references: [id])
  questions                QuizQuestion[]
  sessions                 QuizSession[]
  createdAt                DateTime       @default(now())
}

model QuizQuestion {
  id           String             @id @default(cuid())
  quizId       String
  quiz         Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type         TriviaQuestionType @default(QUIZ)
  text         String
  options      Json               @default("[]")
  correctIndex Int                @default(0)
  config       Json               @default("{}")
  mediaKey     String?
  mediaUrl     String?
  timeLimitSec Int                @default(20)
  sortOrder    Int                @default(0)
  answers      QuizAnswer[]
}

model QuizSession {
  id                String           @id @default(cuid())
  quizId            String
  quiz              Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  state             QuizSessionState @default(LOBBY)
  currentQuestionId String?
  questionIndex     Int              @default(0)
  questionStartedAt DateTime?
  resultsEndsAt     DateTime?
  endedAt           DateTime?
  answers           QuizAnswer[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model QuizAnswer {
  id             String       @id @default(cuid())
  sessionId      String
  session        QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId     String
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  teamId         String?
  team           Team?        @relation(fields: [teamId], references: [id])
  answerIndex    Int          @default(-1)
  answerValue    Json?
  points         Int          @default(0)
  responseTimeMs Int          @default(0)
  isCorrect      Boolean      @default(false)
  streakAtAnswer Int          @default(0)
  answeredAt     DateTime     @default(now())

  @@unique([sessionId, questionId, userId])
}

model Vote {
  id        String       @id @default(cuid())
  eventId   String
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  config    Json
  open      Boolean      @default(false)
  ballots   VoteBallot[]
  createdAt DateTime     @default(now())
}

model VoteBallot {
  id         String   @id @default(cuid())
  voteId     String
  vote       Vote     @relation(fields: [voteId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  teamId     String?
  team       Team?    @relation(fields: [teamId], references: [id])
  selections Json
  createdAt  DateTime @default(now())

  @@unique([voteId, userId])
}

model ScoreCriterion {
  id        String  @id @default(cuid())
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  maxPoints Int
  sortOrder Int     @default(0)
  scores    Score[]
}

model Score {
  id          String         @id @default(cuid())
  teamId      String
  team        Team           @relation(fields: [teamId], references: [id])
  judgeId     String
  judge       User           @relation("JudgeScores", fields: [judgeId], references: [id])
  criterionId String
  criterion   ScoreCriterion @relation(fields: [criterionId], references: [id])
  points      Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([teamId, judgeId, criterionId])
}

model SpinChallenge {
  id                       String                   @id @default(cuid())
  eventId                  String
  event                    Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  config                   Json
  state                    SpinChallengeState       @default(IDLE)
  participationMode        SpinnerParticipationMode @default(ONE_AT_A_TIME)
  allowGeneralParticipants Boolean                  @default(false)
  allowGroupParticipants   Boolean                  @default(true)
  teamId                   String?
  team                     Team?                    @relation(fields: [teamId], references: [id])
  submissions              SpinSubmission[]
  sessions                 SpinnerSession[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
}

model SpinnerSession {
  id              String              @id @default(cuid())
  challengeId     String
  challenge       SpinChallenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId          String?
  team            Team?               @relation(fields: [teamId], references: [id])
  state           SpinnerSessionState @default(ACTIVE)
  activeUserId    String?
  activeUser      User?               @relation("SpinnerActiveUser", fields: [activeUserId], references: [id])
  startedByUserId String
  startedBy       User                @relation("SpinnerStartedBy", fields: [startedByUserId], references: [id])
  spins           SpinnerSpin[]
  createdAt       DateTime            @default(now())
  endedAt         DateTime?

  @@index([eventId, state])
  @@index([challengeId, state])
}

model SpinnerSpin {
  id             String         @id @default(cuid())
  sessionId      String
  session        SpinnerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  selectedIndex  Int
  selectedOption String
  createdAt      DateTime       @default(now())

  @@index([sessionId, createdAt])
}

model CountdownChallenge {
  id                       String             @id @default(cuid())
  eventId                  String
  event                    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  durationSec              Int                @default(300)
  allowGeneralParticipants Boolean            @default(true)
  allowGroupParticipants   Boolean            @default(false)
  sessions                 CountdownSession[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

model CountdownSession {
  id                String                @id @default(cuid())
  challengeId       String
  challenge         CountdownChallenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  eventId           String
  event             Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  state             CountdownSessionState @default(RUNNING)
  segmentDurationMs Int
  startedAt         DateTime?
  pausedRemainingMs Int?
  startedByUserId   String
  startedBy         User                  @relation("CountdownStartedBy", fields: [startedByUserId], references: [id])
  createdAt         DateTime              @default(now())
  endedAt           DateTime?

  @@index([eventId, state])
  @@index([challengeId, state])
}

model TicTacToeChallenge {
  id                       String                    @id @default(cuid())
  eventId                  String
  event                    Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  mode                     TicTacToeMode             @default(CHAMPION)
  competitionFormat        ActivityCompetitionFormat @default(SINGLE_MATCH)
  targetWins               Int                       @default(1)
  config                   Json                      @default("{}")
  allowGeneralParticipants Boolean                   @default(false)
  allowGroupParticipants   Boolean                   @default(true)
  matches                  TicTacToeMatch[]
  bracket                  ActivityBracket?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model TicTacToeMatch {
  id              String              @id @default(cuid())
  challengeId     String
  challenge       TicTacToeChallenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamXId         String
  teamX           Team                @relation("TttTeamX", fields: [teamXId], references: [id])
  teamOId         String
  teamO           Team                @relation("TttTeamO", fields: [teamOId], references: [id])
  state           TicTacToeMatchState @default(WAITING)
  board           Json
  currentTurn     String              @default("X")
  turnNumber      Int                 @default(0)
  councilVotes    Json                @default("{}")
  championXUserId String?
  championX       User?               @relation("TttChampionX", fields: [championXUserId], references: [id])
  championOUserId String?
  championO       User?               @relation("TttChampionO", fields: [championOUserId], references: [id])
  winnerTeamId    String?
  winnerTeam      Team?               @relation("TttWinner", fields: [winnerTeamId], references: [id])
  bracketSlotId   String?
  bracketSlot     ActivityBracketSlot? @relation(fields: [bracketSlotId], references: [id], onDelete: SetNull)
  isDraw          Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  finishedAt      DateTime?

  @@index([eventId, state])
  @@index([challengeId, state])
  @@index([bracketSlotId])
}

model HangmanChallenge {
  id                       String                    @id @default(cuid())
  eventId                  String
  event                    Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  mode                     HangmanMode               @default(CHAMPION)
  competitionFormat        ActivityCompetitionFormat @default(SINGLE_MATCH)
  targetWins               Int                       @default(1)
  config                   Json                      @default("{}")
  maxWrongGuesses          Int                       @default(6)
  allowGeneralParticipants Boolean                   @default(false)
  allowGroupParticipants   Boolean                   @default(true)
  matches                  HangmanMatch[]
  bracket                  ActivityBracket?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model HangmanMatch {
  id              String            @id @default(cuid())
  challengeId     String
  challenge       HangmanChallenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamXId         String
  teamX           Team              @relation("HangmanTeamX", fields: [teamXId], references: [id])
  teamOId         String
  teamO           Team              @relation("HangmanTeamO", fields: [teamOId], references: [id])
  state           HangmanMatchState @default(WAITING)
  secretWord      String            @default("")
  guessedLetters  Json              @default("[]")
  wrongGuessesX   Int               @default(0)
  wrongGuessesO   Int               @default(0)
  currentTurn     String            @default("X")
  turnNumber      Int               @default(0)
  councilVotes    Json              @default("{}")
  championXUserId String?
  championX       User?             @relation("HangmanChampionX", fields: [championXUserId], references: [id])
  championOUserId String?
  championO       User?             @relation("HangmanChampionO", fields: [championOUserId], references: [id])
  winnerTeamId    String?
  winnerTeam      Team?             @relation("HangmanWinner", fields: [winnerTeamId], references: [id])
  bracketSlotId   String?
  bracketSlot     ActivityBracketSlot? @relation(fields: [bracketSlotId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  finishedAt      DateTime?

  @@index([eventId, state])
  @@index([challengeId, state])
  @@index([bracketSlotId])
}

model ActivityBracket {
  id                 String                @id @default(cuid())
  eventId            String
  event              Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gameType           String
  tttChallengeId     String?               @unique
  tttChallenge       TicTacToeChallenge?   @relation(fields: [tttChallengeId], references: [id], onDelete: Cascade)
  hangmanChallengeId String?               @unique
  hangmanChallenge   HangmanChallenge?     @relation(fields: [hangmanChallengeId], references: [id], onDelete: Cascade)
  state              ActivityBracketState  @default(SETUP)
  targetWins         Int                   @default(1)
  currentRound       Int                   @default(0)
  championTeamId     String?
  championTeam       Team?                 @relation("BracketChampion", fields: [championTeamId], references: [id])
  rounds             ActivityBracketRound[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([eventId, state])
}

model ActivityBracketRound {
  id          String                    @id @default(cuid())
  bracketId   String
  bracket     ActivityBracket           @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  roundNumber Int
  state       ActivityBracketRoundState @default(PENDING)
  slots       ActivityBracketSlot[]
  createdAt   DateTime                  @default(now())

  @@unique([bracketId, roundNumber])
}

model ActivityBracketSlot {
  id           String                   @id @default(cuid())
  roundId      String
  round        ActivityBracketRound     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamAId      String
  teamA        Team                     @relation("BracketSlotTeamA", fields: [teamAId], references: [id])
  teamBId      String?
  teamB        Team?                    @relation("BracketSlotTeamB", fields: [teamBId], references: [id])
  teamAWins    Int                      @default(0)
  teamBWins    Int                      @default(0)
  winnerTeamId String?
  winnerTeam   Team?                    @relation("BracketSlotWinner", fields: [winnerTeamId], references: [id])
  isBye        Boolean                  @default(false)
  state        ActivityBracketSlotState @default(PENDING)
  tttMatches   TicTacToeMatch[]
  hangmanMatches HangmanMatch[]
  createdAt    DateTime                 @default(now())

  @@index([roundId, state])
}

model SpinSubmission {
  id          String        @id @default(cuid())
  challengeId String
  challenge   SpinChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team          @relation(fields: [teamId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  payload     Json
  createdAt   DateTime      @default(now())

  @@unique([challengeId, teamId])
}

model AppSetting {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([eventId, key])
}

model AuditLog {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model Survey {
  id                       String           @id @default(cuid())
  eventId                  String
  event                    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title                    String
  status                   SurveyStatus     @default(DRAFT)
  allowGeneralParticipants Boolean          @default(true)
  allowGroupParticipants   Boolean          @default(false)
  opensAt                  DateTime?
  closesAt                 DateTime?
  allowEditsUntilClose     Boolean          @default(true)
  questions                SurveyQuestion[]
  responses                SurveyResponse[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

model SurveyQuestion {
  id        String             @id @default(cuid())
  surveyId  String
  survey    Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type      SurveyQuestionType
  text      String
  config    Json               @default("{}")
  mediaKey  String?
  mediaUrl  String?
  required  Boolean            @default(false)
  sortOrder Int                @default(0)
  answers   SurveyAnswer[]
}

model SurveyResponse {
  id          String         @id @default(cuid())
  surveyId    String
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  submittedAt DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  answers     SurveyAnswer[]

  @@unique([surveyId, userId])
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      Json
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([responseId, questionId])
}
